name: rapidpro
services:
  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile
      - caddy_data:/data
      - caddy_config:/config
  nginx:
    image: nginx
    volumes:
      - "./nginx/default.conf:/etc/nginx/conf.d/default.conf"
      - static_data:/rapidpro/sitestatic
      - "./certs:/etc/nginx/certs"   #Es para que nginx pueda resolver el hostname de courier, con https://courier.internal
    networks: #Es para que nginx pueda resolver el hostname de courier, con https://courier.internal
      default:
        aliases:
          - courier.internal

  postgres:
    image: postgres:17-alpine
    volumes:
      - ./postgres/init_dbs.sql:/docker-entrypoint-initdb.d/dev_dbs.sql
      - postgres:/var/lib/postgresql/data
    ports:
      - 5432:5432
    environment:
      POSTGRES_PASSWORD: tembatemba
    mem_reservation: 1g # Resource optimization
    healthcheck:
      test: ["CMD-SHELL", "pg_isready"]
      interval: 10s
      timeout: 5s

  elastic:
    image: elasticsearch:8.14.0
    volumes:
      - elastic:/usr/share/elasticsearch/data
    ports:
      - 9200:9200
    environment:
      discovery.type: single-node
      xpack.security.enabled: false
      ingest.geoip.downloader.enabled: false
      logger.level: INFO
      ES_JAVA_OPTS: -Xms2g -Xmx2g # Memory optimization for your VM
    mem_reservation: 2g # Resource optimization
    mem_limit: 4g # Resource optimization
    healthcheck:
      # Improved healthcheck: waits for cluster status to be yellow or green
      test: ["CMD-SHELL", "curl -s -f http://localhost:9200/_cluster/health?wait_for_status=yellow&timeout=5s || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10

  valkey:
    image: valkey/valkey:8.0-alpine
    command: valkey-server --save 60 1 --loglevel warning
    volumes:
      - valkey:/data
    ports:
      - 6379:6379
    healthcheck:
      test: ["CMD", "valkey-cli", "ping"]
      interval: 5s
      timeout: 2s
  minio:
    image: minio/minio:latest
    command: server /data --console-address ":9001"
    ports:
      - 9000:9000
      - 9001:9001
    environment:
      MINIO_ROOT_USER: root
      MINIO_ROOT_PASSWORD: tembatemba
    volumes:
      - minio_data:/data

  minio-init:
    image: minio/mc
    depends_on:
      - minio
    volumes:
      - ./minio/init-minio.sh:/init.sh
    entrypoint: >
      /bin/sh -c "
      sleep 5;
      chmod +x /init.sh;
      /init.sh;
      "

  localstack:
    image: localstack/localstack:latest
    volumes:
      - localstack:/var/lib/localstack
    ports:
      - 4566:4566
    environment:
      SERVICES: dynamodb
      AWS_ACCESS_KEY_ID: root
      AWS_SECRET_ACCESS_KEY: tembatemba
      AWS_DEFAULT_REGION: us-east-1
      LOCALSTACK_AUTH_TOKEN: ${LOCALSTACK_AUTH_TOKEN}
    healthcheck:
      test: ["CMD-SHELL", "curl -s http://localhost:4566/_localstack/health >/dev/null || exit 1"]
      interval: 10s
      timeout: 5s

  rapidpro:
    image: nyaruka/rapidpro:stable
    volumes:
      - static_data:/rapidpro/sitestatic
    build:
      context: ./rapidpro/
      args:
        - RAPIDPRO_TAG=mi-custom-v26
    command: ["webapp"]
    depends_on:
      postgres:
        condition: service_healthy
      elastic:
        condition: service_healthy
      valkey:
        condition: service_healthy
      localstack:
        condition: service_healthy
      mailroom:
        condition: service_started
    ports:
      - 8000:8000
    mem_reservation: 1g # Resource optimization
    environment:
      MAILROOM_URL: http://mailroom:8090
      MAILROOM_AUTH_TOKEN: topsecret
      EMAIL_HOST: smtp.gmail.com
      EMAIL_PORT: 587
      EMAIL_HOST_USER: ${EMAIL_HOST_USER}
      EMAIL_HOST_PASSWORD: ${EMAIL_HOST_PASSWORD}
      EMAIL_USE_TLS: "true"
      EMAIL_USE_SSL: "false"
      DEFAULT_FROM_EMAIL: ${EMAIL_HOST_USER}
      FLOW_FROM_EMAIL: ${EMAIL_HOST_USER}
    healthcheck:
      test: curl -s http://localhost:8000 >/dev/null || exit 1
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 20s

  celery:
    image: nyaruka/rapidpro:stable
    build:
      context: ./rapidpro/
      args:
        - RAPIDPRO_TAG=mi-custom-v26
    command: ["celery"]
    depends_on:
      # Celery depends on the same core services as rapidpro
      postgres:
        condition: service_healthy
      valkey:
        condition: service_healthy
      rapidpro: # Still needs rapidpro to be up for some configurations
        condition: service_healthy
    environment:
      MAILROOM_URL: http://mailroom:8090
      MAILROOM_AUTH_TOKEN: topsecret

  mailroom:
    image: nyaruka/mailroom:stable
    volumes: ##para testear https en dev
      - "./certs/courier.crt:/usr/local/share/ca-certificates/courier.crt"
    build: 
      context: https://github.com/nyaruka/mailroom.git#v26.0.0
      dockerfile: Dockerfile
    depends_on:
      # More resilient dependencies
      postgres:
        condition: service_healthy
      valkey:
        condition: service_healthy
      elastic:
        condition: service_healthy
      localstack:
        condition: service_healthy
      minio:
        condition: service_started
      minio-init:
        condition: service_completed_successfully
    ports:
      - 8090:8090
    environment:
      MAILROOM_ADDRESS: 0.0.0.0
      MAILROOM_DB: postgres://temba:temba@postgres:5432/temba?sslmode=disable
      MAILROOM_VALKEY: valkey://valkey:6379/15
      MAILROOM_ELASTIC: http://elastic:9200
      # MAILROOM_DOMAIN: courier:8080
      # MAILROOM_ATTACHMENT_DOMAIN: courier:8080
      MAILROOM_DOMAIN: courier.internal
      MAILROOM_ATTACHMENT_DOMAIN: courier.internal
      MAILROOM_DISALLOWED_NETWORKS: 6.6.6.6
      MAILROOM_AUTH_TOKEN: topsecret
      MAILROOM_COURIER_AUTH_TOKEN: topsecret
      MAILROOM_AWS_ACCESS_KEY_ID: root
      MAILROOM_AWS_SECRET_ACCESS_KEY: tembatemba
      MAILROOM_DYNAMO_ENDPOINT: http://localstack:4566
      MAILROOM_DYNAMO_TABLE_PREFIX: Test #Temba
      MAILROOM_S3_ENDPOINT: http://minio:9000
      MAILROOM_S3_PATH_STYLE: true
      MAILROOM_S3_SESSIONS_BUCKET: temba-sessions
      MAILROOM_S3_ATTACHMENTS_BUCKET: temba-attachments
      MAILROOM_LOG_LEVEL: info

  courier:
    image: nyaruka/courier:stable
    build: 
      context: https://github.com/nyaruka/courier.git#v26.0.1
      dockerfile: Dockerfile
    depends_on:
      # More resilient dependencies
      postgres:
        condition: service_healthy
      valkey:
        condition: service_healthy
      localstack:
        condition: service_healthy
    ports:
      - 8080:8080
    environment:
      COURIER_ADDRESS: 0.0.0.0
      COURIER_DB: postgres://temba:temba@postgres:5432/temba?sslmode=disable
      COURIER_VALKEY: valkey://valkey:6379/15
      COURIER_DOMAIN: courier:8080
      COURIER_BASE_URL: courier:8080
      COURIER_DISALLOWED_NETWORKS: 6.6.6.6
      COURIER_AUTH_TOKEN: topsecret
      COURIER_AWS_ACCESS_KEY_ID: root
      COURIER_AWS_SECRET_ACCESS_KEY: tembatemba
      COURIER_DYNAMO_ENDPOINT: http://localstack:4566
      COURIER_DYNAMO_TABLE_PREFIX: Test #Temba
      COURIER_S3_ENDPOINT: http://minio:9000
      COURIER_S3_ATTACHMENTS_BUCKET: temba-attachments
      COURIER_S3_PATH_STYLE: true
      COURIER_LOG_LEVEL: info

  indexer:
    image: nyaruka/indexer:stable
    build: 
      context: https://github.com/nyaruka/rp-indexer.git#v26.0.1
      dockerfile: Dockerfile
    depends_on:
      # More resilient dependencies
      postgres:
        condition: service_healthy
      elastic:
        condition: service_healthy
    environment:
      INDEXER_DB: postgres://temba:temba@postgres:5432/temba?sslmode=disable
      INDEXER_ELASTIC_URL: http://elastic:9200
      INDEXER_LOG_LEVEL: info

volumes:
  postgres:
    driver: local
  elastic:
    driver: local
  valkey:
    driver: local
  localstack:
    driver: local
  caddy_data:
    driver: local
  caddy_config:
    driver: local
  minio_data:
    driver: local
  static_data: